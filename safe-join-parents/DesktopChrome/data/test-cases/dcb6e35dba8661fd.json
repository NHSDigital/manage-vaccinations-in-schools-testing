ils_path\n        )\n        with spec_file_path.open(\"r\", encoding=\"utf-8\") as file:\n            lines = file.readlines()\n    \n        spec_lines = [\n            line.strip().replace(\"\\r\\n\", \"\\n\").replace(\"\\r\", \"\\n\").replace(\"\\n\\n\", \"\\n\")\n            for line in lines\n        ]\n    \n        self.page.wait_for_load_state()\n        self.import_format_details_link.click()\n        main_content = self.page.get_by_role(\"main\").inner_text()\n        for line in spec_lines:\n            if line not in main_content:\n                missing_line_msg = f\"Inconsistent import format details: {line}\"\n>               raise AssertionError(missing_line_msg)\nE               AssertionError: Inconsistent import format details: VACCINE_GIVEN\tOptional, must be one of: Cervarix, Gardasil, Gardasil9, Sequirus Cell-based Trivalent, AstraZeneca Fluenz, Viatris, Sanofi Vaxigrip, MenQuadfi, Menveo, Nimenrix, Priorix, VaxPro, Revaxis, ProQuad or Priorix-Tetra.\n\nmavis/test/pages/imports/import_records_wizard_page.py:278: AssertionError","flaky":false,"newFailed":false,"newBroken":false,"newPassed":false,"retriesCount":2,"retriesStatusChange":false,"beforeStages":[{"name":"_verify_url","time":{"start":1768583460047,"stop":1768583460047,"duration":0},"status":"passed","steps":[],"attachments":[],"parameters":[],"shouldDisplayMessage":false,"stepsCount":0,"attachmentsCount":0,"hasContent":false,"attachmentStep":false},{"name":"_session_faker","time":{"start":1768583460047,"stop":1768583460048,"duration":1},"status":"passed","steps":[],"attachments":[],"parameters":[],"shouldDisplayMessage":false,"stepsCount":0,"attachmentsCount":0,"hasContent":false,"attachmentStep":false},{"name":"base_url","time":{"start":1768583460047,"stop":1768583460047,"duration":0},"status":"passed","steps":[],"attachments":[],"parameters":[],"shouldDisplayMessage":false,"stepsCount":0,"attachmentsCount":0,"hasContent":false,"attachmentStep":false},{"name":"pytestconfig","time":{"