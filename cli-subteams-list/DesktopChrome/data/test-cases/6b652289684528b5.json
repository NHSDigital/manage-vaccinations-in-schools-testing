   - Output indicates successful import of records.\n        Scenarios covered:\n        HPV:\n        HPV_Optional, HPV_Gardasil9, HPV_Gardasil, HPV_Cervarix, HPV_NFA, HPV_Add_Not_Known,\n        HPV_AllowPastExpiryDate, HPV_SiteRAU, HPV_SiteRAL, HPV_NotVaccinated,\n        HPV_AddressNFA, HPV_AddressNotKnown, HPV_AddressNotSpecified\n        Doubles:\n        TDIPV_Optional, TDIPV_NFA, TDIPV_Add_Not_Known, TDIPV_AllowPastExpiryDate,\n        TDIPV_SiteRAU, TDIPV_SiteRAL, TDIPV_NotVaccinated, MenACWY_Optional, MenACWY_NFA,\n        MenACWY_Add_Not_Known, MenACWY_AllowPastExpiryDate, MenACWY_SiteRAU,MenACWY_SiteRAL,\n        MenACWY_NotVaccinated, MenACWY_BatchName100Chars,\n        Flu:\n        Flu_Optional, Flu_NFA,\n        Flu_Add_Not_Known, Flu_AllowPastExpiryDate, Flu_SiteRAU, Flu_SiteRAL,\n        Flu_NotVaccinated, Flu_BatchName100Chars,\n        MMR:\n        MMR_Optional, MMR_NFA, MMR_Add_Not_Known,\n        MMR_AllowPastExpiryDate, MMR_SiteRAU, MMR_SiteRAL, MMR_NotVaccinated,\n        MMR_BatchName100Chars, MMR_DoseSeq1WithoutSess, MMR_DoseSeq2WithoutSess,\n        MMR_UnknownDoseSeq, MMRNoDelayDose1, MMRNoDelayDose2, MMR_NoDelayDoseUnknown\n        \"\"\"\n>       ImportRecordsWizardPage(page, file_generator).read_and_verify_import_format_details(\n            ImportFormatDetails.VACCS\n        )\n\ntests/test_import_offline_vaccinations.py:79: \n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \n\nself = <mavis.test.pages.imports.import_records_wizard_page.ImportRecordsWizardPage object at 0x7f3c1fd8e450>\nimport_format_details_mapping = <ImportFormatDetails.VACCS: 'vaccs'>\n\n    def read_and_verify_import_format_details(\n        self, import_format_details_mapping: ImportFormatDetails\n    ) -> None:\n        # Use ImportFormatDetails to get file path\n        data_dir = Path(__file__).resolve().parents[2] / \"data\"\n        spec_file_path = (\n            data_dir / import_format_details_mapping.import_format_details_path\n        )\n        with spec_file_path.open(\"r\", encoding=\"utf-8\") as file:\n            lines = file.readlines()\n    \n        spec_lines = [\n            line.strip().replace(\"\\r\\n\", \"\\n\").replace(\"\\r\", \"\\n\").replace(\"\\n\\n\", \"\\n\")\n            for line in lines\n        ]\n    \n        self.page.wait_for_load_state()\n        self.import_format_details_link.click()\n        main_content = self.page.get_by_role(\"main\").inner_text()\n        for line in spec_lines:\n            if line not in main_content:\n                missing_line_msg = f\"Inconsistent import format details: {line}\"\n>               raise AssertionError(missing_line_msg)\nE               AssertionError: Inconsistent import format details: VACCINE_GIVEN\tOptional, must be one of: Cervarix, Gardasil, Gardasil9, Sequirus Cell-based Trivalent, AstraZeneca Fluenz, Viatris, Sanofi Vaxigrip, MenQuadfi, Menveo, Nimenrix, Priorix, VaxPro, Revaxis, ProQuad or Priorix-Tetra.\n\nmavis/test/pages/imports/import_records_wizard_page.py:278: AssertionError","flaky":false,"newFailed":false,"newBroken":false,"newPassed":false,"retriesCount":0,"retriesStatusChange":false,"beforeStages":[{"name":"_verify_url","time":{"start":1768575596962,"stop":1768575596962,"duration":0},"status":"passed","steps":[],"attachments":[],"parameters":[],"shouldDisplayMessage":false,"stepsCount":0,"attachmentsCount":0,"hasContent":false,"attachmentStep":false},{"name":"base_url","time":{"start":1768575596962,"stop":1768575596962,"duration":0},"status":"passed","steps":[],"attachments":[],"parameters":[],"shouldDisplayMessage":false,"stepsCount":0,"attachmentsCount":0,"hasContent":false,"attachmentStep":false},{"name":"_session_faker","time":{"start":1768575596962,"stop":1768575596963,"duration":1},"status":"passed","steps":[],"attachments":[],"parameters":[],"shouldDisplayMessage":false,"stepsCount":0,"attachmentsCount":0,"hasContent":false,"attachmentStep":false},{"name":"delete_output_dir","time":